+    def _determine_architecture(self):
+        """Determine GPU architecture and override driver hint if needed"""
+        # First, try to get architecture from device name
+        self.architecture = self._get_architecture_from_device_name(self.name)
+        
+        # Override driver hint for architectures that don't support open kernel
+        if self.architecture in OPEN_UNSUPPORTED_ARCHS:
+            logging.debug(
+                "Architecture override: %s (%s) requires proprietary driver",
+                self.name, self.architecture
+            )
+            self.driver_hint = proprietary_required
+
+    def _get_architecture_from_device_name(self, device_name):
+        """Try to extract architecture from device name"""
+        if not device_name:
+            return "unknown"
+        
+        name_upper = device_name.upper()
+        
+        # Check for architecture patterns in the name
+        if any(x in name_upper for x in ["MAXWELL", "GM10", "GM20", "GM20", "750", "900", "950", "GTX 750", "GTX 950"]):
+            return "maxwell"
+        if any(x in name_upper for x in ["PASCAL", "GP10", "1000", "1050", "1060", "1070", "1080", "GTX 10", "GTX 1080"]):
+            return "pascal"
+        if "VOLTA" in name_upper or "GV" in name_upper or "TITAN V" in name_upper:
+            return "volta"
+        if any(x in name_upper for x in ["TURING", "TU10", "TU1", "2000", "1660", "1650", "RTX 20", "GTX 16"]):
+            return "turing"
+        if any(x in name_upper for x in ["AMPERE", "GA10", "3000", "3050", "3060", "3070", "3080", "RTX 30"]):
+            return "ampere"
+        if any(x in name_upper for x in ["ADA", "AD10", "4000", "4050", "4060", "4070", "4080", "RTX 40"]):
+            return "ada"
+        if "HOPPER" in name_upper or "GH" in name_upper or "H100" in name_upper:
+            return "hopper"
+        if any(x in name_upper for x in ["FERMI", "GF", "500", "550", "560", "570", "580", "GTX 5"]):
+            return "fermi"
+        if any(x in name_upper for x in ["KEPLER", "GK", "600", "650", "660", "670", "680", "690", "GTX 6"]):
+            return "kepler"
+        if any(x in name_upper for x in ["TESLA", "GT200", "GTX 200", "GTX 280", "GTX 285"]):
