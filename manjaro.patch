+def manjaro_get_legacy_branch(devices):
+    """Get legacy branch from devices for Manjaro"""
+    legacy_branches = []
+    for dev in devices.values():
+        if dev.legacy_branch:
+            try:
+                branch_num = int(dev.legacy_branch.split(".")[0])
+                legacy_branches.append(branch_num)
+            except (ValueError, AttributeError):
+                continue
+    if legacy_branches:
+        return str(min(legacy_branches))  # Return the oldest (smallest) branch number
+    return None

