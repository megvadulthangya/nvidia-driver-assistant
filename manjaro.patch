+    def _determine_architecture(self):
+        """Determine GPU architecture and override driver hint if needed"""
+        # Try to get architecture from chip family if available
+        if hasattr(self, 'chip_family') and self.chip_family:
+            self.architecture = self._get_architecture_from_chip_family(self.chip_family)
+        
+        # If still unknown, try from device name
+        if self.architecture == "unknown":
+            self.architecture = self._get_architecture_from_device_name(self.name)
+        
+        # Override driver hint for architectures that don't support open kernel
+        if self.architecture in OPEN_UNSUPPORTED_ARCHS:
+            logging.debug(
+                "Architecture override: %s (%s) requires proprietary driver",
+                self.name, self.architecture
+            )
+            self.driver_hint = proprietary_required
+        # Legacy drivers <= 470 always need proprietary
+        elif self.legacy_branch and self.legacy_branch.split(".")[0] <= "470":
+            self.driver_hint = proprietary_required
+
+    def _get_architecture_from_chip_family(self, chip_family):
+        if not chip_family:
+            return "unknown"
+        
+        chip_family = chip_family.upper()
+        
+        # Modern architectures
+        if chip_family.startswith("GM"):
+            return "maxwell"
+        if chip_family.startswith("GP"):
+            return "pascal"
+        if chip_family.startswith("GV"):
+            return "volta"
+        if chip_family.startswith("TU"):
+            return "turing"
+        if chip_family.startswith("GA"):
+            return "ampere"
+        if chip_family.startswith("AD"):
+            return "ada"
+        if chip_family.startswith("GH"):
+            return "hopper"
+        
+        # Older architectures
+        if chip_family.startswith("GF"):
+            return "fermi"
+        if chip_family.startswith("GK"):
+            return "kepler"
+        if chip_family.startswith("GT"):  # Tesla 2.0
+            return "tesla2"
+        if chip_family.startswith("G9"):  # Tesla 1.0
+            return "tesla1"
+        if chip_family.startswith("G7"):  # Curie
+            return "curie"
+        if chip_family.startswith("NV"):  # pre-Curie
+            return "pre-curie"
+        
+        return "unknown"
+
+    def _get_architecture_from_device_name(self, device_name):
+        """Try to extract architecture from device name as fallback"""
+        if not device_name:
+            return "unknown"
+        
+        name_upper = device_name.upper()
+        arch_patterns = [
+            ("MAXWELL", "maxwell"), ("PASCAL", "pascal"), ("VOLTA", "volta"),
+            ("TURING", "turing"), ("AMPERE", "ampere"), ("ADA", "ada"),
+            ("HOPPER", "hopper"), ("FERMI", "fermi"), ("KEPLER", "kepler"),
+            ("TESLA", "tesla2"), ("CURIE", "curie"), ("GEFORCE", "unknown")
+        ]
+        
+        for pattern, arch in arch_patterns:
+            if pattern in name_upper:
+                return arch
+        
+        return "unknown"
 
 
