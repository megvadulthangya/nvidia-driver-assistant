+def manjaro_get_legacy_branch(devices):
+    """Get legacy branch from devices for Manjaro"""
+    for dev in devices.values():
+        if dev.legacy_branch:
+            logging.debug(
+                "get_legacy_branch(): %s belongs to legacybranch = %s"
+                % (dev.name, dev.legacy_branch)
+            )
+            return dev.legacy_branch.split('.')[0]
+    return None
+
+
+def manjaro_get_kernel_package():
+    """Get kernel package name for Manjaro (e.g., linux618 from 6.18.xx)"""
+    import platform
+    kernel_release = platform.release().split(".")
+    if len(kernel_release) >= 2:
+        return f"linux{kernel_release[0]}{kernel_release[1]}"
+    return "linux"
+
+
+def get_architecture_aware_driver_hint(devices):
+    """Apply architecture-based overrides to driver hints"""
+    for dev in devices.values():
+        if dev.architecture in OPEN_UNSUPPORTED_ARCHS:
+            logging.debug(
+                "Architecture override: %s (%s) requires proprietary driver",
+                dev.name, dev.architecture
+            )
+            dev.driver_hint = proprietary_required
+    
+    # Return the updated hints list
+    return [dev.driver_hint for dev in devices.values()]
+
